with

recent as (

    select
        id,
        name

    from users

    where
        active = true

    order by created_at desc

    limit 10

)

select
    r.id,
    r.name,
    count(o.id) as order_count

from
    recent as r
left join
    orders as o
    on r.id = o.user_id

group by
    r.id,
    r.name;
