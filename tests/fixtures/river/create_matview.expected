CREATE MATERIALIZED VIEW report.service_subscription_info AS
  SELECT sp.account_id,
         sp.subscription_id,
         sp.plan_id,
         bt.term,
         p.plan_name,
         pf.units_included,
         pf.units_increment,
         pf.price_increment,
         sp.cancelled_at
    FROM public.subscriptions AS sp
    JOIN public.plans AS p
   USING (plan_id)

         INNER JOIN public.plan_details AS pd
         USING (plan_id)

         INNER JOIN public.pricing_fees AS pf
         USING (plan_detail_id)

         INNER JOIN public.features AS f
         USING (feature_id)

         INNER JOIN public.billing_terms AS bt
         USING (billing_term_id)
   WHERE sp.cancelled_at IS NULL OR sp.cancelled_at > CURRENT_TIMESTAMP
     AND f.feature_name = 'notifications'::TEXT
ORDER BY sp.cancelled_at DESC, sp.started_at
WITH NO DATA;
